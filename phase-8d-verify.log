# Phase 8d verify — Cursor plugin management routes
# Generated: 2026-07-10T02:12:04Z (fake SnapshotFetcher; no live Cursor calls)
# Plugin driven in-process via management.handle dispatch.

## management.register (called on plugin boot)
    {
          "routes": [
            {
              "Description": "List Cursor accounts CPA has registered, one status object per account.",
              "Menu": "Cursor accounts",
              "Method": "GET",
              "Path": "/cli-proxy-api/cursor/accounts"
            },
            {
              "Description": "Return one account's rich status (?email=...).",
              "Method": "GET",
              "Path": "/cli-proxy-api/cursor/account"
            },
            {
              "Description": "Force a JWT refresh for a specific account (?email=...).",
              "Method": "POST",
              "Path": "/cli-proxy-api/cursor/account/refresh"
            },
            {
              "Description": "Bust the AccountStatus cache and re-fetch from Cursor (?email=...).",
              "Method": "POST",
              "Path": "/cli-proxy-api/cursor/account/probe"
            },
            {
              "Description": "Aggregate view of the Cursor pool for the admin dashboard.",
              "Method": "GET",
              "Path": "/cli-proxy-api/cursor/pool-summary"
            }
          ]
        }

